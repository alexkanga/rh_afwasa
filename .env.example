# ============================================
# RH AFWASA - Configuration
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs

# Base de données PostgreSQL (obligatoire)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# JWT Secret pour l'authentification (changez en production!)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Compte Fantomas (Super Admin fantôme)
# Email:    fantomas@afwasa.org
# Mot de passe: Fantomas@2024!
# Ce compte est recréé automatiquement si la base est réinitialisée.
# Il n'y a pas besoin de le configurer ici — les identifiants sont codés en dur dans src/lib/phantom-admin.ts